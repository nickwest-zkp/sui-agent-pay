# Standalone backend port
PORT=8787

# Optional API key. If set, frontend requests must send the same value via x-agent-pay-key.
AGENT_PAY_API_KEY=

# Browser CORS. Use your Vercel frontend origin in production, or "*" for demo/testing.
CORS_ORIGIN=http://localhost:3000

# Public backend URL used in Telegram approval links.
# Telegram inline buttons require a public HTTPS URL.
APP_BASE_URL=http://localhost:8787

# Sui network selection: sui-localnet | sui-devnet | sui-testnet | sui-mainnet
SUI_NETWORK=sui-testnet
SUI_FULLNODE_URL=

# Published Move package and shared object ids.
# Leave empty on sui-testnet to use the built-in demo deployment defaults.
SUI_MOVE_PACKAGE_ID=
SUI_VAULT_MODULE=agent_vault
SUI_REGISTRY_MODULE=agent_registry
SUI_VAULT_ID=
SUI_REGISTRY_ID=

# Coin/runtime storage
SUI_COIN_TYPE=0x2::sui::SUI
OWNER_ADDRESS=
DB_PATH=

# Telegram approval delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
