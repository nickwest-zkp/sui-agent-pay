{
  "name": "@sui-agent-pay/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "check-types": "node ./scripts/check-types.mjs",
    "dev": "next dev",
    "format": "prettier --write . '!(node_modules|.next)/**/*'",
    "lint": "eslint .",
    "serve": "next start",
    "start": "next dev",
    "vercel": "vercel --build-env ENABLE_EXPERIMENTAL_COREPACK=1 --build-env VERCEL_TELEMETRY_DISABLED=1",
    "vercel:login": "vercel login",
    "vercel:yolo": "vercel --build-env ENABLE_EXPERIMENTAL_COREPACK=1 --build-env NEXT_PUBLIC_IGNORE_BUILD_ERROR=true --build-env VERCEL_TELEMETRY_DISABLED=1"
  },
  "dependencies": {
    "@heroicons/react": "~2.1.5",
    "@mysten/dapp-kit-react": "^2.0.1",
    "@mysten/sui": "^2.16.0",
    "@sui-agent-pay/sdk": "file:../../../../packages/sdk",
    "daisyui": "5.0.9",
    "next": "~15.2.8",
    "react": "~19.2.3",
    "react-dom": "~19.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@next/eslint-plugin-next": "~15.2.3",
    "@tailwindcss/postcss": "4.0.15",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "@trivago/prettier-plugin-sort-imports": "~4.3.0",
    "@types/node": "~18.19.50",
    "@types/react": "~19.0.7",
    "eslint": "~9.23.0",
    "eslint-config-next": "~15.2.3",
    "eslint-config-prettier": "~10.1.1",
    "eslint-plugin-prettier": "~5.2.4",
    "globals": "^16.4.0",
    "postcss": "~8.4.45",
    "prettier": "~3.5.3",
    "tailwindcss": "4.1.3",
    "typescript": "~5.8.2",
    "vercel": "~39.1.3"
  },
  "packageManager": "pnpm@10.33.0"
}
