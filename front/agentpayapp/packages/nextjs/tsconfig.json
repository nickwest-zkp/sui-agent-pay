{
  "compilerOptions": {
    "target": "es2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": false,
    "paths": {
      "~~/*": [
        "./*"
      ],
      "@sui-agent-pay/sdk": [
        "../../../../packages/sdk/src/index.ts"
      ],
      "@sui-agent-pay/sdk/*": [
        "../../../../packages/sdk/src/*"
      ],
      "@mysten/sui/cryptography": [
        "./node_modules/@mysten/sui/dist/cryptography/index.d.mts"
      ],
      "@mysten/sui/grpc": [
        "./node_modules/@mysten/sui/dist/grpc/index.d.mts"
      ],
      "@mysten/sui/keypairs/ed25519": [
        "./node_modules/@mysten/sui/dist/keypairs/ed25519/index.d.mts"
      ],
      "@mysten/sui/keypairs/secp256k1": [
        "./node_modules/@mysten/sui/dist/keypairs/secp256k1/index.d.mts"
      ],
      "@mysten/sui/keypairs/secp256r1": [
        "./node_modules/@mysten/sui/dist/keypairs/secp256r1/index.d.mts"
      ],
      "@mysten/sui/transactions": [
        "./node_modules/@mysten/sui/dist/transactions/index.d.mts"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next-dev/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-prod/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
