# Copy this file to `.env.local` for local development.

# Sui network selection: sui-localnet | sui-devnet | sui-testnet | sui-mainnet
NEXT_PUBLIC_SUI_NETWORK=sui-testnet

# Optional override. Leave empty to use the default RPC for the selected network.
NEXT_PUBLIC_SUI_FULLNODE_URL=

# Published Move package and shared object ids
# Leave empty on sui-testnet to use the built-in demo deployment defaults.
NEXT_PUBLIC_SUI_MOVE_PACKAGE_ID=
NEXT_PUBLIC_SUI_VAULT_MODULE=agent_vault
NEXT_PUBLIC_SUI_REGISTRY_MODULE=agent_registry
NEXT_PUBLIC_SUI_VAULT_ID=
NEXT_PUBLIC_SUI_REGISTRY_ID=

# Coin metadata used by the frontend console
NEXT_PUBLIC_SUI_COIN_TYPE=0x2::sui::SUI
NEXT_PUBLIC_SUI_COIN_SYMBOL=SUI
NEXT_PUBLIC_SUI_COIN_DECIMALS=9

# Standalone backend URL. Set this to the public backend origin in Vercel.
# If empty, the frontend falls back to same-origin /api/* proxy routes.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8787

# Optional server-side backend URL for same-origin /api/* proxy and Telegram callbacks through the frontend.
BACKEND_URL=http://localhost:8787

# Optional API key mirrored to backend AGENT_PAY_API_KEY.
NEXT_PUBLIC_AGENT_PAY_API_KEY=
